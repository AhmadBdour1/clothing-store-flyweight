package com.clothingstore;

import com.sun.net.httpserver.HttpServer;
import com.sun.net.httpserver.HttpHandler;
import com.sun.net.httpserver.HttpExchange;

import java.io.IOException;
import java.io.OutputStream;
import java.net.InetSocketAddress;
import java.nio.file.Files;
import java.nio.file.Paths;
import java.util.concurrent.Executors;

public class Main {

    private static ClothingStore store = new ClothingStore();
    private static final String WEB_ROOT = "./resources/web";

    public static void main(String[] args) throws IOException {
        // Pre-load data
        preloadData();

        HttpServer server = HttpServer.create(new InetSocketAddress(8000), 0);

        // Serve static files
        server.createContext("/", new StaticFileHandler());
        server.createContext("/api/inventory", new InventoryHandler());
        server.createContext("/api/stats", new StatsHandler());

        server.setExecutor(Executors.newFixedThreadPool(10)); // creates a default executor
        server.start();
        System.out.println("Server started on port 8000");
        System.out.println("Access the application at http://localhost:8000");
    }

    private static void preloadData() {
        // 4-5 clothing items with some shared models to demonstrate Flyweight
        store.addClothingItem("T-Shirt", "Nike", "Graphic Tee", "Blue", "Cotton", 25.00, "images/nike_blue_tshirt.png", "M", "NKGTB001M", "A1", 10);
        store.addClothingItem("T-Shirt", "Nike", "Graphic Tee", "Blue", "Cotton", 25.00, "images/nike_blue_tshirt.png", "L", "NKGTB001L", "A2", 15);
        store.addClothingItem("T-Shirt", "Adidas", "Striped Tee", "Red", "Cotton", 22.00, "images/adidas_red_tshirt.png", "M", "ADST002M", "B1", 8);
        store.addClothingItem("Jeans", "Levi's", "501 Original", "Blue", "Denim", 60.00, "images/levis_blue_jeans.png", "32x32", "LV501B003", "C1", 5);
        store.addClothingItem("Jacket", "Puma", "Windbreaker", "Black", "Polyester", 50.00, "images/puma_black_jacket.png", "L", "PMWB004L", "D1", 7);
        store.addClothingItem("T-Shirt", "Nike", "Graphic Tee", "Green", "Cotton", 25.00, "images/nike_green_tshirt.png", "M", "NKGTG005M", "A3", 12);
    }

    static class StaticFileHandler implements HttpHandler {
        @Override
        public void handle(HttpExchange exchange) throws IOException {
            String path = exchange.getRequestURI().getPath();
            if (path.equals("/")) {
                path = "/index.html"; // Default to index.html
            }

            java.nio.file.Path filePath = Paths.get(WEB_ROOT, path).normalize();

            if (!filePath.startsWith(Paths.get(WEB_ROOT).normalize())) {
                // Prevent directory traversal attacks
                String response = "403 Forbidden";
                exchange.sendResponseHeaders(403, response.length());
                OutputStream os = exchange.getResponseBody();
                os.write(response.getBytes());
                os.close();
                return;
            }

            if (Files.exists(filePath) && !Files.isDirectory(filePath)) {
                String contentType = getContentType(filePath.toString());
                exchange.getResponseHeaders().set("Content-Type", contentType);
                exchange.sendResponseHeaders(200, Files.size(filePath));
                OutputStream os = exchange.getResponseBody();
                Files.copy(filePath, os);
                os.close();
            } else {
                String response = "404 Not Found";
                exchange.sendResponseHeaders(404, response.length());
                OutputStream os = exchange.getResponseBody();
                os.write(response.getBytes());
                os.close();
            }
        }

        private String getContentType(String filePath) {
            if (filePath.endsWith(".html")) return "text/html";
            if (filePath.endsWith(".css")) return "text/css";
            if (filePath.endsWith(".js")) return "application/javascript";
            if (filePath.endsWith(".png")) return "image/png";
            if (filePath.endsWith(".jpg") || filePath.endsWith(".jpeg")) return "image/jpeg";
            return "application/octet-stream";
        }
    }

    static class InventoryHandler implements HttpHandler {
        @Override
        public void handle(HttpExchange exchange) throws IOException {
            String response = store.getInventoryJson();
            exchange.getResponseHeaders().set("Content-Type", "application/json");
            exchange.sendResponseHeaders(200, response.length());
            OutputStream os = exchange.getResponseBody();
            os.write(response.getBytes());
            os.close();
        }
    }

    static class StatsHandler implements HttpHandler {
        @Override
        public void handle(HttpExchange exchange) throws IOException {
            String response = store.getFlyweightStatsJson();
            exchange.getResponseHeaders().set("Content-Type", "application/json");
            exchange.sendResponseHeaders(200, response.length());
            OutputStream os = exchange.getResponseBody();
            os.write(response.getBytes());
            os.close();
        }
    }
}
